
package foodorderingsystem;


import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;

public class DatabaseConnection {
    private static final String URL = "jdbc:mysql://localhost:3306/FoodOrderingSystem";
    private static final String USER = "root"; // غيّريها لو عندك مستخدم مختلف
    private static final String PASSWORD = "Ll123456@"; // حطي كلمة المرور لو فيه

    public static Connection getConnection() {
        try {
            Class.forName("com.mysql.cj.jdbc.Driver");
            Connection conn = DriverManager.getConnection(URL, USER, PASSWORD);
            System.out.println("✅ تم الاتصال بقاعدة البيانات بنجاح!");
            return conn;
        } catch (ClassNotFoundException e) {
            System.out.println("❌ لم يتم العثور على Driver!");
            e.printStackTrace();
        } catch (SQLException e) {
            System.out.println("❌ فشل الاتصال بقاعدة البيانات!");
            e.printStackTrace();
        }
        return null;
    }

 public static void main(String[] args) {
        DatabaseConnection.getConnection(); // هذا بيجرب الاتصال
        new DatabaseConnection();
     
    }}